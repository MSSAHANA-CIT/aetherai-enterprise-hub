# JWT secret for token signing (maps to jwt_secret_key in config)
SECRET_KEY=change-this-secret-key

# OpenAI API configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gmail API OAuth 2.0 (for sending OTP emails)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=AetherAI Security

# OTP and frontend
OTP_EXPIRY_MINUTES=10
FRONTEND_URL=http://localhost:5173

# Production (Railway backend): set to your deployed frontend URL (no trailing slash)
# FRONTEND_URL=https://your-frontend.up.railway.app
#
# Optional: extra allowed origins (comma-separated), e.g. preview deployments
# CORS_ORIGINS=https://your-frontend.up.railway.app

# Local development (optional — defaults to sqlite when unset)
# ENVIRONMENT=development
# DATABASE_URL=sqlite:///./aetherai.db

# Production (Railway): required variables on the backend service
# ENVIRONMENT=production
#
# Railway variable name must be exactly DATABASE_URL (uppercase).
# Link your Postgres plugin or paste the connection string into DATABASE_URL.
#
# Private networking (default Railway Postgres reference):
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# If the backend crashes with:
#   could not translate host name "postgres.railway.internal"
# private networking is not resolving. Use the public Postgres URL instead:
# DATABASE_URL=${{Postgres.DATABASE_PUBLIC_URL}}
